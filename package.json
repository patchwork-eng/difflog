{
  "name": "difflog",
  "version": "1.0.0",
  "description": "Generate a human-readable changelog from your git commits",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "build": "ncc build src/index.js -o dist --license licenses.txt",
    "prepare": "npm run build"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "worker/src/**/*.js"
    ]
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^20.1.1",
    "@sentry/node": "^8.0.0",
    "openai": "^4.47.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@vercel/ncc": "^0.38.1",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0"
  },
  "keywords": [
    "github-action",
    "changelog",
    "ai",
    "openai",
    "devtools"
  ],
  "author": "patchwork-eng",
  "license": "MIT"
}
